{
  "name": "rust",
  "build": {
    "dockerfile": "Dockerfile",
  },
  "runArgs": [
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges",
    "--pids-limit=256",
    "--memory=2g",
  ],
  "remoteUser": "devuser",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=${localEnv:HOME}/.config/fish,target=/tmp/fish-config,type=bind,readonly",
    "source=${localWorkspaceFolderBasename}-cargo,target=/home/devuser/cache,type=volume",
  ],
  "containerEnv": {
    "CARGO_HOME": "/home/devuser/cache/.cargo",
    "CARGO_TARGET_DIR": "/home/devuser/cache/target",
  },
  "postCreateCommand": "mkdir -p ~/.config/fish && if [ -d /tmp/fish-config ]; then cp -rn /tmp/fish-config/. ~/.config/fish/; fi",
}
